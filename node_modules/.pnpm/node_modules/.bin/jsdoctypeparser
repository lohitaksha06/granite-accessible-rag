#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/c/Lohit/software/granite-accessible-rag/node_modules/.pnpm/jsdoctypeparser@9.0.0/node_modules/jsdoctypeparser/bin/node_modules:/mnt/c/Lohit/software/granite-accessible-rag/node_modules/.pnpm/jsdoctypeparser@9.0.0/node_modules/jsdoctypeparser/node_modules:/mnt/c/Lohit/software/granite-accessible-rag/node_modules/.pnpm/jsdoctypeparser@9.0.0/node_modules:/mnt/c/Lohit/software/granite-accessible-rag/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/c/Lohit/software/granite-accessible-rag/node_modules/.pnpm/jsdoctypeparser@9.0.0/node_modules/jsdoctypeparser/bin/node_modules:/mnt/c/Lohit/software/granite-accessible-rag/node_modules/.pnpm/jsdoctypeparser@9.0.0/node_modules/jsdoctypeparser/node_modules:/mnt/c/Lohit/software/granite-accessible-rag/node_modules/.pnpm/jsdoctypeparser@9.0.0/node_modules:/mnt/c/Lohit/software/granite-accessible-rag/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../jsdoctypeparser/bin/jsdoctypeparser" "$@"
else
  exec node  "$basedir/../jsdoctypeparser/bin/jsdoctypeparser" "$@"
fi
